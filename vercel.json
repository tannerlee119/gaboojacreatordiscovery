{
  "functions": {
    "app/api/analyze-creator/route.ts": {
      "maxDuration": 60
    },
    "app/api/data-quality/route.ts": {
      "maxDuration": 30
    },
    "app/api/ai-metrics/route.ts": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ],
  "env": {
    "VERCEL": "1"
  }
} 